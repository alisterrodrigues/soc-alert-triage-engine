# SOC Alert Triage Engine — environment variables
# Copy this file to .env and fill in your values.
# Never commit a .env file with real keys.

# VirusTotal API key (free tier: 4 requests/min)
# https://www.virustotal.com/gui/join-us
VT_API_KEY=your_virustotal_api_key_here

# Shodan API key
# https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# Splunk credentials (only needed when using --source splunk)
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=your_splunk_password_here

# Elasticsearch API key (preferred, only needed when using --source elastic)
# https://www.elastic.co/guide/en/elasticsearch/reference/current/security-api-create-api-key.html
ELASTIC_API_KEY=your_elastic_api_key_here

# Elasticsearch username/password fallback
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=your_elastic_password_here
